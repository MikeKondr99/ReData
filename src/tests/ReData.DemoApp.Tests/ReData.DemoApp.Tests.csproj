<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <IsTestProject>true</IsTestProject>
        <NoWarn>CA1707</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="FastEndpoints.Testing"/>
        <!-- BASE -->
        <PackageReference Include="coverlet.collector"/>
        <PackageReference Include="Microsoft.NET.Test.Sdk"/>
        <PackageReference Include="Respawn" />
        <PackageReference Include="xunit"/>
        <PackageReference Include="Xunit.SkippableFact"/>
        <PackageReference Include="FluentAssertions"/>
        <PackageReference Include="xunit.runner.visualstudio" />

        <PackageReference Include="TestContainers"/>
        <PackageReference Include="TestContainers.PostgreSql"/>
    </ItemGroup>

    <ItemGroup>
        <Content Include="xunit.runner.json" CopyToOutputDirectory="Always"/>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="$(SolutionDir)\src\apps\ReData.DemoApp\ReData.DemoApp.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Update="Init\Data\test.csv">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
      <None Update="Init\Data\numbers.csv">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
      <None Update="Init\Data\single.csv">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
      <None Update="Init\Data\empty.csv">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
    </ItemGroup>

</Project>
